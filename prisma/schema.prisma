// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionLabel {
  LEETCODE
  STRIVER
  REVISION
  CONTEST
  NOTES
  DEBUGGING
  MOCK_INTERVIEW
  MANUAL
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  createdAt    DateTime  @default(now())

  sessions Session[]

  @@map("users")
}

model Session {
  id        String       @id @default(cuid())
  userId    String
  label     SessionLabel @default(LEETCODE)
  startTime DateTime
  endTime   DateTime?
  duration  Int?         // in seconds
  notes     String?
  tags      String[]
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}
