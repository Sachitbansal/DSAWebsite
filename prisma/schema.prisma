// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum SessionLabel {
  LEETCODE
  STRIVER
  REVISION
  CONTEST
  NOTES
  DEBUGGING
  MOCK_INTERVIEW
}

enum Platform {
  LEETCODE
  CODEFORCES
  ATCODER
  HACKERRANK
  GFGS
  STRIVER
  OTHER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  sessions       Session[]
  problems       Problem[]
  revisions      Revision[]
  journalEntries JournalEntry[]
  algorithmNotes AlgorithmNote[]
  patterns       Pattern[]
  dailyReviews   DailyReview[]

  @@map("users")
}

model Session {
  id        String       @id @default(cuid())
  userId    String
  label     SessionLabel @default(LEETCODE)
  startTime DateTime
  endTime   DateTime?
  duration  Int?         // in seconds
  notes     String?
  tags      String[]
  createdAt DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Problem {
  id                  String     @id @default(cuid())
  userId              String
  name                String
  platform            Platform   @default(LEETCODE)
  difficulty          Difficulty @default(MEDIUM)
  topics              String[]
  solvedIndependently Boolean    @default(true)
  timeTaken           Int?       // in minutes
  revisionCount       Int        @default(0)
  confidenceRating    Int        @default(3) // 1-5
  notes               String?
  url                 String?
  dateSolved          DateTime   @default(now())
  nextRevisionDate    DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  revisions Revision[]
  journal   JournalEntry[]

  @@map("problems")
}

model Revision {
  id              String   @id @default(cuid())
  problemId       String
  userId          String
  revisedAt       DateTime @default(now())
  notes           String?
  confidenceAfter Int      @default(3) // 1-5

  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("revisions")
}

model JournalEntry {
  id                 String   @id @default(cuid())
  userId             String
  problemId          String?
  title              String
  initialThought     String?
  stuckPoint         String?
  wrongIntuition     String?
  correctIntuition   String?
  missedPattern      String?
  implementationBug  String?
  edgeCaseMissed     String?
  learningOutcome    String?
  tags               String[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem? @relation(fields: [problemId], references: [id], onDelete: SetNull)

  @@map("journal_entries")
}

model AlgorithmNote {
  id           String   @id @default(cuid())
  userId       String
  category     String
  title        String
  content      String   // markdown
  codeSnippets Json     @default("[]")
  complexity   Json     @default("{}")
  tricks       String?
  edgeCases    String?
  templates    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("algorithm_notes")
}

model Pattern {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String?
  examples       Json     @default("[]")
  linkedProblems String[]
  tags           String[]
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patterns")
}

model DailyReview {
  id           String   @id @default(cuid())
  userId       String
  date         DateTime @db.Date
  wentWell     String?
  wastedTime   String?
  wasDifficult String?
  improveNext  String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_reviews")
}
