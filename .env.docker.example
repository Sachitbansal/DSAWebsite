# Copy this to .env.docker and fill in values

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret_here_min_32_chars

# For local testing:
NEXTAUTH_URL=http://localhost:8001

# For production server:
# NEXTAUTH_URL=https://dsa.iitmandi.co.in

# Optional: change DB password (default: dsa_password)
# DB_PASSWORD=stronger_password_here

# Optional: change host port (default: 8001)
# APP_PORT=8001
